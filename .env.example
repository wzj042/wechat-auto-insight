# LLM provider: deepseek or zhipu.
GROUP_INSIGHT_PROVIDER=deepseek

# DeepSeek configuration.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# Zhipu configuration.
ZHIPUAI_API_KEY=your-zhipu-api-key
ZHIPUAI_MODEL=glm-4.5-flash

# Optional generic overrides used by python -m group_insight.
# GROUP_INSIGHT_API_KEY=
# GROUP_INSIGHT_MODEL=
