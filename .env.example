# DeepSeek configuration.
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-v4-flash
# as enabled/disabled
THINKING=false
# as high/max
THINKING_LEVEL=high
DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# 异常告警邮箱配置（可选）。当 RPA 发送失败时，会尝试向以下地址发送告警邮件。
# 支持 QQ/163/企业微信邮箱等，密码通常填写 SMTP 授权码。
# ALERT_SMTP_HOST=smtp.qq.com
# ALERT_SMTP_PORT=465
# ALERT_SMTP_USER=your_email@qq.com
# ALERT_SMTP_PASSWORD=your_smtp_auth_code
# ALERT_FROM=your_email@qq.com
# ALERT_TO=receiver1@example.com,receiver2@example.com
